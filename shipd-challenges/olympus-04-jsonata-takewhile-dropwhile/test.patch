+"use strict";
+
+var jsonata = require('../src/jsonata');
+var chai = require("chai");
+var expect = chai.expect;
+var chaiAsPromised = require("chai-as-promised");
+chai.use(chaiAsPromised);
+
+function evaluate(expr, data) {
+    return jsonata(expr).evaluate(data);
+}
+
+describe('$takeWhile', function () {
+    it('returns the leading run where the predicate holds', function () {
+        return expect(evaluate('$takeWhile([1,2,3,4,1,2], function($x){ $x < 4 })'))
+            .to.eventually.deep.equal([1, 2, 3]);
+    });
+
+    it('stops at the first falsy result even if a later element would pass', function () {
+        // single remaining element is returned as a scalar (jsonata sequence semantics)
+        return expect(evaluate('$takeWhile([1,5,2], function($x){ $x < 3 })'))
+            .to.eventually.equal(1);
+    });
+
+    it('passes the element index as the second argument', function () {
+        return expect(evaluate('$takeWhile([10,20,30], function($v,$i){ $i < 2 })'))
+            .to.eventually.deep.equal([10, 20]);
+    });
+
+    it('returns nothing when the first element fails', function () {
+        return expect(evaluate('$takeWhile([1,2,3], function($x){ $x > 100 })'))
+            .to.eventually.equal(undefined);
+    });
+
+    it('returns undefined for undefined input', function () {
+        return expect(evaluate('$takeWhile($missing, function($x){ true })'))
+            .to.eventually.equal(undefined);
+    });
+});
+
+describe('$dropWhile', function () {
+    it('drops the leading run where the predicate holds', function () {
+        return expect(evaluate('$dropWhile([1,2,3,4,1,2], function($x){ $x < 4 })'))
+            .to.eventually.deep.equal([4, 1, 2]);
+    });
+
+    it('keeps everything once the predicate first fails', function () {
+        return expect(evaluate('$dropWhile([1,5,2], function($x){ $x < 3 })'))
+            .to.eventually.deep.equal([5, 2]);
+    });
+
+    it('drops everything when the predicate always holds', function () {
+        return expect(evaluate('$dropWhile([1,2], function($x){ $x < 100 })'))
+            .to.eventually.equal(undefined);
+    });
+
+    it('returns undefined for undefined input', function () {
+        return expect(evaluate('$dropWhile($missing, function($x){ true })'))
+            .to.eventually.equal(undefined);
+    });
+
+    it('is the complement of $takeWhile', function () {
+        // takeWhile followed by dropWhile reconstructs the original array
+        return expect(evaluate(
+            '$append($takeWhile([1,2,3,4,1], function($x){ $x < 4 }), ' +
+            '$dropWhile([1,2,3,4,1], function($x){ $x < 4 }))'
+        )).to.eventually.deep.equal([1, 2, 3, 4, 1]);
+    });
+});
