+    /**
+     * Return the leading elements of an array while a predicate holds
+     * @param {Array} [arr] - array to take from
+     * @param {Function} [func] - predicate function
+     * @returns {Array} the longest leading run for which func is truthy
+     */
+    async function takeWhile(arr, func) {
+        // undefined inputs always return undefined
+        if (typeof arr === 'undefined') {
+            return undefined;
+        }
+
+        var result = this.createSequence();
+
+        for (var i = 0; i < arr.length; i++) {
+            var entry = arr[i];
+            var func_args = hofFuncArgs(func, entry, i, arr);
+            // invoke func
+            var res = await func.apply(this, func_args);
+            if (!boolean(res)) {
+                break;
+            }
+            result.push(entry);
+        }
+
+        return result;
+    }
+
+    /**
+     * Drop the leading elements of an array while a predicate holds
+     * @param {Array} [arr] - array to drop from
+     * @param {Function} [func] - predicate function
+     * @returns {Array} the remaining elements once func first becomes falsy
+     */
+    async function dropWhile(arr, func) {
+        // undefined inputs always return undefined
+        if (typeof arr === 'undefined') {
+            return undefined;
+        }
+
+        var result = this.createSequence();
+        var dropping = true;
+
+        for (var i = 0; i < arr.length; i++) {
+            var entry = arr[i];
+            if (dropping) {
+                var func_args = hofFuncArgs(func, entry, i, arr);
+                // invoke func
+                var res = await func.apply(this, func_args);
+                if (boolean(res)) {
+                    continue;
+                }
+                dropping = false;
+            }
+            result.push(entry);
+        }
+
+        return result;
+    }
