index 0000000..2449653
--- /dev/null
+++ b/tests/approximate_5545d6.test.js
@@ -0,0 +1,236 @@
+'use strict';
+
+const assert = require('assert');
+const Fraction = require('fraction.js');
+
+// Exhaustive best rational approximation with denominator <= N, used as the
+// ground truth. Iterates q ascending and only replaces on a strictly smaller
+// distance, so ties resolve toward the smaller denominator (matching the spec).
+function bruteBest(x, N) {
+  let best = null;
+  let bestDist = null;
+  for (let q = 1; q <= N; q++) {
+    const xq = x.mul(new Fraction(q));
+    const candidates = [xq.floor(), xq.ceil()];
+    for (let j = 0; j < candidates.length; j++) {
+      const frac = candidates[j].div(new Fraction(q));
+      const dist = frac.sub(x).abs();
+      if (bestDist === null || dist.compare(bestDist) < 0) {
+        best = frac;
+        bestDist = dist;
+      }
+    }
+  }
+  return best;
+}
+
+// Reads a fraction's denominator through the public toFraction() output, so
+// the assertions stay on behavior rather than internal fields.
+function denomOf(f) {
+  const s = f.toFraction();
+  const slash = s.indexOf('/');
+  return slash < 0 ? 1n : BigInt(s.slice(slash + 1));
+}
+
+// Deterministic PRNG (mulberry32) so the suite is stable across the 6x
+// flakiness runs.
+function rng(seed) {
+  let a = seed >>> 0;
+  return function () {
+    a |= 0; a = (a + 0x6D2B79F5) | 0;
+    let t = Math.imul(a ^ (a >>> 15), 1 | a);
+    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
+    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+  };
+}
+
+describe('Fraction#approximate', function () {
+  it('is exposed as a method', function () {
+    assert.strictEqual(typeof new Fraction(1, 3).approximate, 'function');
+    assert.ok(new Fraction(1, 3).approximate(10) instanceof Fraction);
+  });
+
+  it('returns the value unchanged when it already fits the budget', function () {
+    assert.ok(new Fraction(3, 4).approximate(10).equals(new Fraction(3, 4)));
+    assert.ok(new Fraction(3, 4).approximate(4).equals(new Fraction(3, 4)));
+    assert.ok(new Fraction(7).approximate(1).equals(new Fraction(7)));
+  });
+
+  it('finds the classic approximations of pi', function () {
+    const pi = new Fraction(Math.PI);
+    assert.ok(pi.approximate(1).equals(new Fraction(3)));
+    assert.ok(pi.approximate(7).equals(new Fraction(22, 7)));
+    assert.ok(pi.approximate(56).equals(new Fraction(22, 7)));
+    assert.ok(pi.approximate(99).equals(new Fraction(311, 99)));
+    assert.ok(pi.approximate(106).equals(new Fraction(333, 106)));
+  });
+
+  it('handles zero and negative values', function () {
+    assert.ok(new Fraction(0).approximate(5).equals(new Fraction(0)));
+    const negPi = new Fraction(Math.PI).neg();
+    assert.ok(negPi.approximate(7).equals(new Fraction(-22, 7)));
+    assert.ok(negPi.approximate(1).equals(new Fraction(-3)));
+  });
+
+  it('accepts a BigInt limit', function () {
+    const pi = new Fraction(Math.PI);
+    assert.ok(pi.approximate(7n).equals(new Fraction(22, 7)));
+  });
+
+  it('never exceeds the denominator budget', function () {
+    const r = rng(12345);
+    for (let i = 0; i < 200; i++) {
+      const num = Math.floor(r() * 20000) - 10000;
+      const den = Math.floor(r() * 9999) + 1;
+      const N = Math.floor(r() * 60) + 1;
+      const approx = new Fraction(num, den).approximate(N);
+      assert.ok(denomOf(approx) <= BigInt(N), num + '/' + den + ' @ ' + N + ' -> ' + approx.toFraction());
+    }
+  });
+
+  it('matches an exhaustive brute-force search (battery)', function () {
+    const r = rng(98765);
+    for (let i = 0; i < 400; i++) {
+      const num = Math.floor(r() * 4000) - 2000;
+      const den = Math.floor(r() * 997) + 1;
+      const N = Math.floor(r() * 40) + 1;
+      const x = new Fraction(num, den);
+      const got = x.approximate(N);
+      const want = bruteBest(x, N);
+      assert.ok(
+        got.equals(want),
+        x.toFraction() + ' @ ' + N + ' -> got ' + got.toFraction() + ' want ' + want.toFraction()
+      );
+    }
+  });
+
+  it('matches brute force for irrational-derived targets', function () {
+    const targets = [Math.PI, Math.E, Math.SQRT2, Math.log(2), 1 / 3, 0.1];
+    targets.forEach(function (v) {
+      const x = new Fraction(v);
+      for (let N = 1; N <= 50; N++) {
+        assert.ok(x.approximate(N).equals(bruteBest(x, N)), v + ' @ ' + N);
+      }
+    });
+  });
+
+  it('stays exact for values far beyond double precision', function () {
+    // Build a value from a continued fraction with a huge partial quotient, so
+    // its convergents have coprime denominators well beyond 2^53. A float-based
+    // implementation would collapse these onto doubles and return wrong results.
+    const cf = [0n, 2n, 3n, 100000000000000007n, 5n];
+    let h2 = 0n, h1 = 1n, k2 = 1n, k1 = 0n;
+    const conv = [];
+    for (let i = 0; i < cf.length; i++) {
+      const h = cf[i] * h1 + h2;
+      const k = cf[i] * k1 + k2;
+      conv.push([h, k]);
+      h2 = h1; h1 = h; k2 = k1; k1 = k;
+    }
+    const P = conv[conv.length - 1][0];
+    const Q = conv[conv.length - 1][1];
+    const TWO_53 = 9007199254740992n;
+    const x = new Fraction(P, Q);
+
+    // Budget >= denominator returns the exact value, digit for digit.
+    assert.strictEqual(x.approximate(Q).toFraction(), P.toString() + '/' + Q.toString());
+
+    // Any genuine convergent with a denominator beyond 2^53 must be reproduced
+    // exactly when the budget equals that convergent's denominator.
+    const big = conv.filter(function (c) { return c[1] > TWO_53 && c[1] < Q; });
+    assert.ok(big.length > 0);
+    big.forEach(function (c) {
+      const got = x.approximate(c[1]);
+      assert.strictEqual(got.toFraction(), c[0].toString() + '/' + c[1].toString());
+    });
+
+    // With a budget below the large convergent, the answer must fall back to the
+    // exact small convergent 3/7 (not something a rounded double drifts to).
+    assert.ok(x.approximate(1000n).equals(new Fraction(3, 7)));
+  });
+
+  it('breaks exact-distance ties toward the smaller denominator', function () {
+    // 5/12 sits exactly halfway between 1/3 and 1/2 (both 1/12 away). With a
+    // denominator budget of 3 the two candidates are equidistant, so the one
+    // with the smaller denominator (1/2) must win.
+    const x = new Fraction(5, 12);
+    const got = x.approximate(3);
+    assert.ok(got.equals(new Fraction(1, 2)), 'got ' + got.toFraction());
+    assert.strictEqual(denomOf(got), 2n);
+
+    // Symmetric negative case.
+    assert.ok(new Fraction(-5, 12).approximate(3).equals(new Fraction(-1, 2)));
+  });
+
+  it('throws on an invalid limit', function () {
+    assert.throws(function () { new Fraction(Math.PI).approximate(0); });
+    assert.throws(function () { new Fraction(Math.PI).approximate(-5); });
+  });
+});
+
+describe('TypeScript definitions', function () {
+  const fs = require('fs');
+  const path = require('path');
+
+  function read(file) {
+    return fs.readFileSync(path.resolve(__dirname, '..', file), 'utf8');
+  }
+
+  it('declares the new methods in fraction.d.ts', function () {
+    const dts = read('fraction.d.ts');
+    assert.ok(/approximate\s*\(/.test(dts), 'fraction.d.ts must declare approximate');
+    assert.ok(/convergents\s*\(/.test(dts), 'fraction.d.ts must declare convergents');
+  });
+
+  it('declares the new methods in fraction.d.mts', function () {
+    const mts = read('fraction.d.mts');
+    assert.ok(/approximate\s*\(/.test(mts), 'fraction.d.mts must declare approximate');
+    assert.ok(/convergents\s*\(/.test(mts), 'fraction.d.mts must declare convergents');
+  });
+});
+
+describe('Fraction#convergents', function () {
+  it('returns the continued-fraction convergents, ending at the exact value', function () {
+    const x = new Fraction(415, 93); // [4; 2, 6, 7]
+    const c = x.convergents();
+    assert.ok(Array.isArray(c));
+    assert.ok(c[0].equals(new Fraction(4)));
+    assert.ok(c[1].equals(new Fraction(9, 2)));
+    assert.ok(c[2].equals(new Fraction(58, 13)));
+    assert.ok(c[c.length - 1].equals(x));
+  });
+
+  it('produces convergents that straddle the value and improve monotonically', function () {
+    const x = new Fraction(Math.PI);
+    const c = x.convergents();
+    let prevErr = null;
+    for (let i = 0; i < c.length; i++) {
+      const err = c[i].sub(x).abs();
+      if (prevErr !== null) {
+        assert.ok(err.compare(prevErr) <= 0, 'convergent errors must not increase');
+      }
+      prevErr = err;
+    }
+    assert.ok(c[c.length - 1].equals(x));
+  });
+
+  it('each convergent is the best approximation within its own denominator', function () {
+    // Theorem: p_k/q_k is the best rational approximation among all fractions
+    // with denominator <= q_k, so approximate(q_k) must return that convergent.
+    [Math.E, Math.PI, Math.SQRT2, 415 / 93].forEach(function (v) {
+      const x = new Fraction(v);
+      // Skip the 0th convergent (the integer part): when the fractional part
+      // exceeds 1/2 the nearest integer is a strictly better denominator-1
+      // approximation, so it is a special case of the theorem.
+      x.convergents().slice(1).forEach(function (conv) {
+        assert.ok(x.approximate(denomOf(conv)).equals(conv), v + ' @ ' + conv.toFraction());
+      });
+    });
+  });
+
+  it('handles integers and negatives', function () {
+    assert.ok(new Fraction(5).convergents().pop().equals(new Fraction(5)));
+    const c = new Fraction(-7, 3).convergents();
+    assert.ok(c.pop().equals(new Fraction(-7, 3)));
+  });
+});
