+import assert from 'node:assert/strict'
+import { describe, it } from 'node:test'
+import markdownit from '../../index.mjs'
+
+describe('abbreviations', function () {
+  const md = markdownit()
+
+  it('wraps a defined abbreviation in an abbr tag with its title', function () {
+    assert.equal(
+      md.render('The HTML spec.\n\n*[HTML]: HyperText Markup Language'),
+      '<p>The <abbr title="HyperText Markup Language">HTML</abbr> spec.</p>\n'
+    )
+  })
+
+  it('handles multiple definitions and repeated use', function () {
+    assert.equal(
+      md.render('HTML and CSS, then HTML again.\n\n*[HTML]: HyperText Markup Language\n*[CSS]: Cascading Style Sheets'),
+      '<p><abbr title="HyperText Markup Language">HTML</abbr> and ' +
+      '<abbr title="Cascading Style Sheets">CSS</abbr>, then ' +
+      '<abbr title="HyperText Markup Language">HTML</abbr> again.</p>\n'
+    )
+  })
+
+  it('respects word boundaries', function () {
+    assert.equal(
+      md.render('HTML5 and HTML end.\n\n*[HTML]: HyperText Markup Language'),
+      '<p>HTML5 and <abbr title="HyperText Markup Language">HTML</abbr> end.</p>\n'
+    )
+  })
+
+  it('works when the definition appears after the use', function () {
+    assert.equal(
+      md.render('Use HTML here.\n\n*[HTML]: HyperText Markup Language'),
+      '<p>Use <abbr title="HyperText Markup Language">HTML</abbr> here.</p>\n'
+    )
+  })
+
+  it('escapes special characters in the title', function () {
+    assert.equal(
+      md.render('W3C rules.\n\n*[W3C]: World Wide Web Consortium & friends'),
+      '<p><abbr title="World Wide Web Consortium &amp; friends">W3C</abbr> rules.</p>\n'
+    )
+  })
+
+  it('does not wrap an undefined abbreviation', function () {
+    assert.equal(md.render('Just HTML here.'), '<p>Just HTML here.</p>\n')
+  })
+
+  it('does not wrap abbreviations inside code spans', function () {
+    assert.equal(
+      md.render('`HTML` code.\n\n*[HTML]: HyperText Markup Language'),
+      '<p><code>HTML</code> code.</p>\n'
+    )
+  })
+
+  it('does not touch ordinary markdown', function () {
+    const out = md.render('Just **bold** and a [link](http://x.com).')
+    assert.equal(out, '<p>Just <strong>bold</strong> and a <a href="http://x.com">link</a>.</p>\n')
+    assert.ok(!out.includes('<abbr'))
+  })
+
+  it('does not leak definitions between renders', function () {
+    const md2 = markdownit()
+    assert.equal(
+      md2.render('HTML one.\n\n*[HTML]: HyperText Markup Language'),
+      '<p><abbr title="HyperText Markup Language">HTML</abbr> one.</p>\n'
+    )
+    // second render has no definition, so nothing should be wrapped
+    assert.equal(md2.render('HTML two.'), '<p>HTML two.</p>\n')
+  })
+})
