+#!/usr/bin/env bash
+# Shipd test runner for Fraction.js.
+#
+# Usage:
+#   test.sh [base|new|all] --output_path <path>
+#   test.sh --mode <base|new|all> --output_path <path>
+#
+#   base -> run only the pre-existing (baseline) tests
+#   new  -> run only the tests added by this problem
+#   all  -> run the whole suite (default)
+#
+# Writes JUnit XML to <path> via mocha's xunit reporter and exits with mocha's
+# own status. Resolves mocha/crude-build from the global install, a local
+# node_modules, or npx WITHOUT ever hitting the network (no package installs
+# happen here; the Dockerfile installs them globally).
+set -u
+
+MODE="all"
+OUTPUT_PATH=""
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --mode) MODE="$2"; shift 2 ;;
+    --mode=*) MODE="${1#*=}"; shift ;;
+    base|new|all) MODE="$1"; shift ;;
+    --output_path) OUTPUT_PATH="$2"; shift 2 ;;
+    --output_path=*) OUTPUT_PATH="${1#*=}"; shift ;;
+    *) shift ;;
+  esac
+done
+
+if [ -z "$OUTPUT_PATH" ]; then
+  echo "usage: test.sh [base|new|all] --output_path <path>" >&2
+  exit 2
+fi
+
+# Resolve a binary from local node_modules, the global install, or offline npx.
+resolve() {
+  local name="$1"
+  if [ -x "node_modules/.bin/$name" ]; then
+    echo "node_modules/.bin/$name"
+  elif command -v "$name" >/dev/null 2>&1; then
+    echo "$name"
+  else
+    echo "npx --no-install $name"
+  fi
+}
+
+BUILD_BIN="$(resolve crude-build)"
+MOCHA_BIN="$(resolve mocha)"
+
+# Rebuild dist/fraction.js from the (possibly patched) src so require('fraction.js')
+# picks up the current code. dist/ is committed, so if the bundler is somehow
+# unavailable the baseline tests still have a working dist to run against.
+$BUILD_BIN Fraction >/dev/null 2>&1 || true
+
+NEW_TEST="tests/approximate_5545d6.test.js"
+
+case "$MODE" in
+  new)
+    FILES="$NEW_TEST"
+    ;;
+  base)
+    FILES="$(ls tests/*.js | grep -v "$(basename "$NEW_TEST")")"
+    ;;
+  *)
+    FILES="$(ls tests/*.js)"
+    ;;
+esac
+
+# mocha writes the JUnit report even on failures and exits non-zero when any
+# test fails; propagate that status.
+$MOCHA_BIN $FILES --reporter xunit --reporter-options output="$OUTPUT_PATH"
+exit $?
diff --git a/tests/approximate_5545d6.test.js b/tests/approximate_5545d6.test.js
