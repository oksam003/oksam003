+#!/usr/bin/env bash
+# Shipd test runner for Fraction.js.
+#
+# Usage:
+#   test.sh [base|new|all] --output_path <path>
+#   test.sh --mode <base|new|all> --output_path <path>
+#
+#   base -> run only the pre-existing (baseline) tests
+#   new  -> run only the tests added by this problem
+#   all  -> run the whole suite (default)
+#
+# Writes JUnit XML to <path> via mocha's xunit reporter and exits with mocha's
+# own status so test failures are visible through the process exit code.
+# Package installation happens in the Dockerfile, not here.
+set -u
+
+MODE="all"
+OUTPUT_PATH=""
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --mode) MODE="$2"; shift 2 ;;
+    --mode=*) MODE="${1#*=}"; shift ;;
+    base|new|all) MODE="$1"; shift ;;
+    --output_path) OUTPUT_PATH="$2"; shift 2 ;;
+    --output_path=*) OUTPUT_PATH="${1#*=}"; shift ;;
+    *) shift ;;
+  esac
+done
+
+if [ -z "$OUTPUT_PATH" ]; then
+  echo "usage: test.sh [base|new|all] --output_path <path>" >&2
+  exit 2
+fi
+
+# Rebuild dist/ from the (possibly patched) src so tests import current code.
+# Building is not a package install; it just regenerates dist/fraction.js.
+npm run build >/dev/null 2>&1
+
+NEW_TEST="tests/approximate_5545d6.test.js"
+
+case "$MODE" in
+  new)
+    FILES="$NEW_TEST"
+    ;;
+  base)
+    FILES="$(ls tests/*.js | grep -v "$(basename "$NEW_TEST")")"
+    ;;
+  *)
+    FILES="$(ls tests/*.js)"
+    ;;
+esac
+
+# Run the tests. mocha writes the JUnit report even on failures and exits
+# non-zero when any test fails; propagate that status.
+npx mocha $FILES --reporter xunit --reporter-options output="$OUTPUT_PATH"
+exit $?
diff --git a/tests/approximate_5545d6.test.js b/tests/approximate_5545d6.test.js
